# Supabase Configuration
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs (from scripts/create-stripe-products.ts)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID
NEXT_PUBLIC_STRIPE_PRICE_STUDENT=price_YOUR_STUDENT_PRICE_ID

# Stripe Annual Price IDs (10% discount)
NEXT_PUBLIC_STRIPE_PRICE_STARTER_ANNUAL=price_YOUR_STARTER_ANNUAL_PRICE_ID
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_YOUR_PRO_ANNUAL_PRICE_ID

# App URL
NEXT_PUBLIC_APP_URL=https://formi.fun
